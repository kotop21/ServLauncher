---
import Layout from '../layouts/Layout.astro';
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Home - Astra Launcher">
  <main class="container">
    
    <div class="main-content">
      <h1 class="general-title">Hello, Astra Launcher</h1>
      <p class="subtitle">A lightweight, lightning-fast <b>open-source</b> workspace tailored for modern Minecraft servers.</p>

      <div class="hero-buttons">
        <a href="https://github.com/kotop21/AstraLauncher/releases/latest"><button>Download</button></a>
        <a href="https://github.com/kotop21/AstraLauncher"><button>GitHub</button></a>
      </div>
    </div>

    <img src={`${baseUrl}/preview.png`} alt="Astra Launcher Preview" loading="eager" class="hero-img" draggable="false" />

    <div class="scroll-hint-wrapper">
      <a href="#" class="scroll-hint" onclick="event.preventDefault(); window.scrollTo({ top: window.innerHeight + 70, behavior: 'smooth' });">Explore Features ↓</a>
    </div>

    <div class="features-container">

      <section class="feature-item">
        <div class="feature-text">
          <h3>All-in-One Server Workspace</h3>
          <p>Track live console logs, send commands, and navigate server files simultaneously. Customize your workspace on the fly — resize the file manager sidebar or hide it completely to focus on the console. Your custom layout width and state are automatically preserved, even after restarting.</p>
        </div>
        <div class="feature-visual">
          <img src={`${baseUrl}/server-control.png`} alt="Server Control Panel Screenshot" draggable="false" />
        </div>
      </section>
      
      <section class="feature-item reverse">
        <div class="feature-text">
          <h3>Centralized Management</h3>
          <p>All your servers are gathered in one place. Switch between consoles, files, and instance logs in a single click.</p>
        </div>
        <div class="feature-visual">
          <img src={`${baseUrl}/preview.png`} alt="Centralized Management Screenshot" />
        </div>
      </section>

      <section class="feature-item">
        <div class="feature-text">
          <h3>Built-in Editor & File Browser</h3>
          <p>Navigate server directories using the built-in sidebar manager and launch the code editor instantly.</p>
        </div>
        <div class="feature-visual">
          <img src={`${baseUrl}/editor.png`} alt="Built-in Editor Screenshot" draggable="false" />
        </div>
      </section>

      <section class="feature-item reverse">
        <div class="feature-text">
          <h3>Instant Core Switching</h3>
          <p>Automatically download popular server jars (Paper, Purpur, Velocity, etc.) straight from the dashboard or instantly drop in your own local .jar.</p>
        </div>
        <div class="feature-visual">
          <img src={`${baseUrl}/core-switching.png`} alt="Core Switching Screenshot" draggable="false" />
        </div>
      </section>

    </div>

    <footer>
      <p>Tailored for server admins by <strong>kotop21</strong></p>
    </footer>

  </main>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  hr {
    margin-top: 30px;
    margin-bottom: 30px;
  }

  footer {
    margin-top: 50px;
    margin-bottom: 50px;
    text-align: center;
  }
  footer p {
     color: lightgray;   
  }

  .main-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-buttons {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 40px;
  }

  .hero-buttons button {
    font-size: 18px;
    padding: 12px 32px;
    font-weight: 600;
  }

  .github-link {
    font-size: 18px;
    font-weight: 600;
    text-decoration: underline;
  }

  .general-title {
    font-size: 56px;
    font-weight: 800;
    letter-spacing: -3px;

    text-shadow:
      0 0 24px rgba(255,255,255,0.08),
      0 0 60px rgba(96,165,250,0.08);
  }

  .subtitle {
    color: lightgray;
    padding: 12px 16px;
  }
  
  .container {
    width: 100%;
    max-width: 1000px;
    padding-top: 15vh;
    margin: 0 auto;
  }

  .hero-img {
    display: block;
    width: 100% !important;
    max-width: 65% !important;
    height: auto;
    margin: 0 auto;
  }

  .scroll-hint-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: -10px;
    margin-bottom: 110px; 
    position: relative;
    z-index: 99999; 
  }

  .scroll-hint {
    color: #666 !important; 
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
    
    padding: 15px 30px; 
    margin: -15px -30px;
    display: inline-block;
    cursor: pointer;
  }

  .scroll-hint:hover {
    color: #999 !important;
  }

  img, video {
    display: block;
    width: 100% !important;
    max-width: 100%;
    height: auto;
    user-select: none;
    -webkit-user-drag: none;
    filter: 
      drop-shadow(0 20px 50px rgba(255, 255, 255, 0.08))
      drop-shadow(0 -15px 40px rgba(255, 255, 255, 0.05));
  }

  .features-container {
    display: flex;
    flex-direction: column;
    gap: 80px;
    width: 100%;
  }

  .feature-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 50px;
    width: 100%;
  }

  .feature-item.reverse {
    flex-direction: row-reverse;
  }

  .feature-text {
    width: 40%;
  }

  .feature-text h3 {
    font-size: 24px;
    margin-bottom: 10px;
    font-weight: 700;
  }

  .feature-text p {
    color: lightgray;
    font-size: 18px;
    margin: 0;
  }

  .feature-visual {
    width: 60%;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .container {
      max-width: 90%;
    }
    .hero-img {
      max-width: 100% !important;
    }
  }

  @media (max-width: 768px) {
    .container {
      max-width: 100%;
      padding: 40px 20px 20px 20px;
    }

    .general-title {
      font-size: 36px;
      letter-spacing: -1px;
    }

    .subtitle {
      font-size: 16px;
      padding: 8px 0;
    }

    .hero-buttons {
      width: 100%;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-buttons a, 
    .hero-buttons button {
      width: 100%;
    }

    .hero-buttons button {
      padding: 14px 24px;
    }

    .feature-item, 
    .feature-item.reverse {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }

    .feature-text,
    .feature-visual {
      width: 100%;
    }

    .features-container {
      gap: 60px;
    }

    .scroll-hint-wrapper {
      display: none;
    }
  }
</style>
