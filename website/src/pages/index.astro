---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <main class="container">
    
    <div class="main-content">
      <h1 class="general-title">Hello, Astra Launcher</h1>
      <p class="subtitle">A lightweight, lightning-fast open-source workspace tailored for modern Minecraft servers.</p>

      <div class="hero-buttons">
        <a href="#"><button>Download</button></a>
        <a href="https://github.com/kotop21/AstraLauncher"><button>GitHub</button></a>
      </div>
    </div>

    <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/preview.png`} alt="Astra Launcher Preview" loading="eager" />

    <h1 class="title">Features</h1>

    <ul>
      <li>
        <strong>Lightning-Fast Interface</strong> — The control panel opens instantly and runs with zero lag, keeping the system lightweight and responsive.
      </li>
      <li>
        <strong>Centralized Management</strong> — All your servers are gathered in one place. Switch between consoles, files, and instance logs in a single click.
      </li>
      <li>
        <strong>Built-in Editor</strong> — Modify configurations and tweak server files directly inside the launcher without relying on third-party text editors.
      </li>
      <li>
        <strong>Instant Core Switching</strong> — Automatically download popular server jars (Paper, Purpur) straight from the dashboard or instantly drop in your own local .jar.
      </li>
      <li>
        <strong>Monorepo Ready</strong> — Perfectly tailored for local development and testing entire networks of multiple servers simultaneously.
      </li>
    </ul>

    <footer>
      <p>Tailored for server admins by <strong>kotop21</strong></p>
    </footer>

  </main>
</Layout>

<style>
  hr {
    margin-top: 30px;
    margin-bottom: 30px;
  }

  li {
    margin-top: 5px;
    margin-bottom: 5px;
  }

  footer {
    margin-top: 50px;
    margin-bottom: 50px;
    text-align: center;
  }
  footer p {
     color: lightgray;   
  }

  .main-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-buttons {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-bottom: 40px;
  }

  .hero-buttons button {
    font-size: 18px;
    padding: 12px 32px;
    font-weight: 600;
  }

  .github-link {
    font-size: 18px;
    font-weight: 600;
    text-decoration: underline;
  }

  .general-title {
    font-size: 56px;
    font-weight: 800;
    letter-spacing: -3px;

    text-shadow:
      0 0 24px rgba(255,255,255,0.08),
      0 0 60px rgba(96,165,250,0.08);
  }
  .title {
    font-size: 45px;
    text-decoration: underline;
  }

  .subtitle {
    color: lightgray;
    padding: 12px 16px;
  }
  
  .container {
    max-width: 46%;
    padding-top: 15vh;
    margin: 0 auto;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
    filter: 
      drop-shadow(0 20px 50px rgba(255, 255, 255, 0.08))
      drop-shadow(0 -15px 40px rgba(255, 255, 255, 0.05));
  }

  @media (max-width: 768px) {
    .container {
      max-width: 100%;
      padding: 40px 20px 20px 20px;
    }

    .general-title {
      font-size: 36px;
      letter-spacing: -1px;
    }

    .title {
      font-size: 28px;
    }

    .subtitle {
      font-size: 16px;
      padding: 8px 0;
    }

    .hero-buttons {
      width: 100%;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-buttons a, 
    .hero-buttons button {
      width: 100%;
    }

    .hero-buttons button {
      padding: 14px 24px;
    }

    ul {
      padding-left: 20px;
    }
  }
</style>
